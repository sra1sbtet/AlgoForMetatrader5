FLASK_HOST=127.0.0.1
FLASK_PORT=5050
FLASK_DEBUG=0

# Leave blank for local SQLite fallback.
# Set this to use PostgreSQL instead:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/algo_system
DATABASE_URL=

# Optional. Leave blank to use the currently logged-in MT5 terminal session.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

DEFAULT_SYMBOL=EURUSD
DEFAULT_VOLUME=0.01
DEFAULT_TIMEFRAME=M1
